<?xml version="1.0"?>
<!--
  URDF para O3DE — LawnMower robot (tracción diferencial real)
  Basado en lawnmower.urdf.xacro (LawnMower-Nav2)

  Diferencias respecto al URDF de Gazebo:
  - Sin plugin gz-sim-diff-drive-system (O3DE usa el ROS2 Gem con DiffDriveComponent)
  - Sin tags <gazebo> — O3DE configura physics en el editor
  - Conserva todos los links/joints para importación correcta en O3DE Editor
  - Sensor frames presentes para attachment en O3DE
-->
<robot name="lawnmower" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- Dimensiones hardware (idénticas al robot real) -->
  <xacro:property name="base_length"  value="0.80"/>
  <xacro:property name="base_width"   value="0.60"/>
  <xacro:property name="base_height"  value="0.25"/>
  <xacro:property name="base_mass"    value="30.0"/>

  <!-- Ruedas motrices MY1016Z3 (WENC_RADIUS=0.125, CPR=28) -->
  <xacro:property name="wheel_radius" value="0.125"/>
  <xacro:property name="wheel_width"  value="0.08"/>
  <xacro:property name="wheel_mass"   value="1.5"/>
  <xacro:property name="wheel_x"      value="-0.20"/>

  <!-- Casters delanteros -->
  <xacro:property name="caster_radius" value="0.05"/>
  <xacro:property name="caster_mass"   value="0.3"/>
  <xacro:property name="caster_x"      value="0.28"/>
  <xacro:property name="caster_y"      value="0.22"/>

  <!-- Offsets sensores -->
  <xacro:property name="lidar_z"  value="0.30"/>   <!-- Unitree L2 -->
  <xacro:property name="gps_z"    value="0.35"/>   <!-- Here4 -->
  <xacro:property name="imu_z"    value="0.00"/>   <!-- Cube Orange+ IMU (dentro chasis) -->

  <!-- REP-105: base_footprint al nivel del suelo -->
  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0.10 0 ${base_height/2}"/>
      <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
      <material name="green"><color rgba="0.1 0.5 0.1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0.10 0 ${base_height/2}"/>
      <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
    </collision>
    <inertial>
      <mass value="${base_mass}"/>
      <origin xyz="0.10 0 ${base_height/2}"/>
      <inertia
        ixx="${base_mass/12 * (base_width*base_width + base_height*base_height)}"
        ixy="0" ixz="0"
        iyy="${base_mass/12 * (base_length*base_length + base_height*base_height)}"
        iyz="0"
        izz="${base_mass/12 * (base_length*base_length + base_width*base_width)}"/>
    </inertial>
  </link>

  <!-- Ruedas motrices (continuous) — O3DE DiffDriveComponent usa estos joints -->
  <xacro:macro name="drive_wheel" params="name y_sign">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="dark_gray"><color rgba="0.2 0.2 0.2 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
      <inertial>
        <mass value="${wheel_mass}"/>
        <inertia
          ixx="${wheel_mass/12 * (3*wheel_radius*wheel_radius + wheel_width*wheel_width)}"
          ixy="0" ixz="0"
          iyy="${wheel_mass/12 * (3*wheel_radius*wheel_radius + wheel_width*wheel_width)}"
          iyz="0"
          izz="${wheel_mass/2 * wheel_radius*wheel_radius}"/>
      </inertial>
    </link>
    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${name}"/>
      <origin xyz="${wheel_x} ${y_sign * base_width/2} 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.01" friction="0.1"/>
      <limit effort="50" velocity="10"/>
    </joint>
  </xacro:macro>

  <xacro:drive_wheel name="left_wheel"  y_sign=" 1"/>
  <xacro:drive_wheel name="right_wheel" y_sign="-1"/>

  <!-- Casters (fixed) — O3DE les asigna material de baja fricción -->
  <xacro:macro name="caster_wheel" params="name y_sign">
    <link name="${name}">
      <visual>
        <geometry><sphere radius="${caster_radius}"/></geometry>
        <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
      </visual>
      <collision>
        <geometry><sphere radius="${caster_radius}"/></geometry>
      </collision>
      <inertial>
        <mass value="${caster_mass}"/>
        <inertia
          ixx="${2.0/5.0 * caster_mass * caster_radius*caster_radius}"
          ixy="0" ixz="0"
          iyy="${2.0/5.0 * caster_mass * caster_radius*caster_radius}"
          iyz="0"
          izz="${2.0/5.0 * caster_mass * caster_radius*caster_radius}"/>
      </inertial>
    </link>
    <joint name="${name}_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="${name}"/>
      <origin xyz="${caster_x} ${y_sign * caster_y} ${caster_radius - wheel_radius}"/>
    </joint>
  </xacro:macro>

  <xacro:caster_wheel name="left_caster"  y_sign=" 1"/>
  <xacro:caster_wheel name="right_caster" y_sign="-1"/>

  <!-- Frames de sensores — se attach-ean en O3DE Editor como entidades hijas -->
  <link name="unilidar_lidar"/>   <!-- Unitree L2 — RGL LiDAR Component -->
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="unilidar_lidar"/>
    <origin xyz="0.05 0 ${lidar_z}" rpy="0 0 0"/>
  </joint>

  <link name="imu_link"/>         <!-- IMU Component — 200Hz gaussian noise -->
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <origin xyz="0 0 ${imu_z}" rpy="0 0 0"/>
  </joint>

  <link name="gps_link"/>         <!-- GNSS Sensor Component — Here4 RTK sim -->
  <joint name="gps_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="gps_link"/>
    <origin xyz="0 0 ${gps_z}" rpy="0 0 0"/>
  </joint>

</robot>
